{
  "name": "dev-draft-pos",
  "version": "1.0.0",
  "description": "Dev Draft – Grocery Point of Sale Desktop App",
  "main": "main.js",
  "author": {
    "name": "Dev Draft",
    "email": "support@devdraft.in"
  },
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.devdraft.pos",
    "productName": "Dev Draft POS",
    "copyright": "Copyright © 2025 Dev Draft",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "executableName": "Dev Draft POS",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "installerHeaderIcon": "assets/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dev Draft POS",
      "menuCategory": "Dev Draft",
      "artifactName": "Dev Draft POS Setup.exe",
      "deleteAppDataOnUninstall": false,
      "license": "LICENSE.txt",
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "electron-pos-printer": "*"
  }
}
